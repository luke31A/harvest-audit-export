# Copy this file to .streamlit/secrets.toml for local development.
# In Streamlit Community Cloud, paste these values into the Secrets dashboard.
# NEVER commit secrets.toml to GitHub.

[harvest]
client_id     = "your_harvest_oauth_client_id"
client_secret = "your_harvest_oauth_client_secret"
redirect_uri  = "https://commitharvestaudit.streamlit.app"
